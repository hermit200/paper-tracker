# LLM API Key (统一环境变量名称，适用于所有 OpenAI 兼容的 API)
# Set this to your API key from any provider (OpenAI, DeepSeek, SiliconFlow, etc.)
# The actual provider is determined by base_url in config YAML
LLM_API_KEY=sk-your-api-key-here

# NCBI API Key (optional, for PubMed data source)
# Without a key: 3 requests/second limit; with a key: 10 requests/second limit.
# Apply for a free key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
